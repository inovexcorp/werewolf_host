# --- Core ---
WW_REDIS_URL=redis://localhost:6379/0
WW_OPENAI_BASE_URL=https://litellm.inovexcorp.com/v1
WW_OPENAI_API_KEY=
WW_NARRATOR_MODEL=openai/gpt-5-mini

# --- Phase timing (seconds) ---
WW_NIGHT_DURATION=45
WW_DISCUSSION_DURATION=90
WW_VOTING_DURATION=30
WW_RUNOFF_VOTING_DURATION=30
WW_MORNING_ANNOUNCEMENT_PAUSE=5
WW_BANISHMENT_REVEAL_PAUSE=5

# --- Rate limits ---
WW_MAX_MESSAGES_PER_DISCUSSION=5
WW_MESSAGE_COOLDOWN_SECONDS=3.0
WW_MAX_MESSAGE_LENGTH=280
WW_TYPING_INDICATOR_TTL=5

# --- Connection ---
WW_AGENT_RESPONSE_TIMEOUT=10
WW_RECONNECT_TIMEOUT=10

# --- Spectator ---
WW_SPECTATOR_WOLF_CHAT_DELAY=0
